{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ObjectRW",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::__BUCKET__/gallery/*"
    },
    {
      "Sid": "ListGalleryOnly",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::__BUCKET__",
      "Condition": { "StringLike": { "s3:prefix": ["gallery/*"] } }
    }
  ]
}
